# waoiw — local config (gitignored)
# Auto-generated by calibrate tool, or edit manually

# Tesseract path (Windows default)
# WAOIW_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Screen regions — set by running: python -m waoiw.tools.calibrate
# Format: {"left": x, "top": y, "width": w, "height": h}
# WAOIW_REGION_HP_BAR={"left": 0, "top": 0, "width": 100, "height": 20}
# WAOIW_REGION_MANA_BAR={"left": 0, "top": 22, "width": 100, "height": 16}
# WAOIW_REGION_MINIMAP={"left": 1720, "top": 20, "width": 200, "height": 200}
# WAOIW_REGION_ACTION_BAR={"left": 600, "top": 1020, "width": 500, "height": 50}

# Timing
# WAOIW_SCREENSHOT_INTERVAL_MS=500
# WAOIW_ACTION_DELAY_MIN_MS=150
# WAOIW_ACTION_DELAY_MAX_MS=400

# Safety
# WAOIW_MAX_SESSION_MINUTES=120
# WAOIW_PAUSE_KEY=F12
